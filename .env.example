# .env.example — Archivo de Ejemplo para Variables de Entorno

# Nunca commitear .env — solo .env.example

# ==== CORE ====
APP_ENV=development
DEBUG=true

# ==== DATABASE ====
DATABASE_URL=postgresql://user:password@localhost:5432/iot_db
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# ==== REDIS ====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==== MQTT ====
MQTT_BROKER=mosquitto.local
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ==== JWT AUTH ====
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# ==== FRONTEND ====
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws

# ==== LOGGING ====
LOG_LEVEL=INFO
LOG_FILE=/var/log/app.log

# ==== SENSORS ====
SENSOR_READ_INTERVAL=5000
SENSOR_MAX_RETRIES=3

# ==== EXTERNAL SERVICES ====
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# ==== ARDUINO / RPi ====
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUDRATE=115200
